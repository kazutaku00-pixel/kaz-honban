# =================================
# NihonGo 本番 — Environment Variables
# =================================
# Copy to .env.local and fill in values. NEVER commit .env.local

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Daily.co ---
DAILY_API_KEY=your-daily-api-key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Cron Security ---
# REQUIRED in production. Without this, cron endpoints are open to public.
# Generate: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# --- Payment Toggle ---
# false = Phase 1 (no payment, free booking)
# true = Phase 2 (PayPal required)
PAYMENT_ENABLED=false

# --- PayPal (Phase 2) ---
# PAYPAL_CLIENT_ID=your-paypal-client-id
# PAYPAL_CLIENT_SECRET=your-paypal-client-secret
# PAYPAL_MODE=sandbox

# --- Resend (Phase 2) ---
# RESEND_API_KEY=re_...

# --- Sentry (Phase 3) ---
# SENTRY_DSN=

# --- PostHog (Phase 3) ---
# NEXT_PUBLIC_POSTHOG_KEY=
